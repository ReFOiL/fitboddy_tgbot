# Фичи
# false — оплата выключена: CRYPTBOT_* не обязательны, у всех доступ как у PREMIUM (см. PremiumAccess).
FEATURE_PAYMENT_ENABLED=true

# Telegram
BOT_TOKEN=change_me

# Database (docker)
DB_PASSWORD=change_me
DATABASE_URL=postgresql+asyncpg://fitboddy:change_me@postgres:5432/fitboddy

# Redis (docker)
REDIS_URL=redis://redis:6379/0

# CryptoBot (обязательны только при FEATURE_PAYMENT_ENABLED=true)
CRYPTBOT_API_TOKEN=change_me
CRYPTBOT_WEBHOOK_SECRET=change_me

# MinIO (docker)
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=change_me
MINIO_ENDPOINT=minio:9000
# Адрес MinIO, с которого открываются ссылки в браузере (админка — просмотр видео). Не задавать = тот же, что MINIO_ENDPOINT.
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_SECURE=false
MINIO_BUCKET=fitboddy

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4318/v1/traces
SERVICE_NAME=fitboddy-bot

# Grafana
GRAFANA_PASSWORD=change_me

# PgAdmin
PGADMIN_DEFAULT_EMAIL=admin@fitboddy.local
PGADMIN_DEFAULT_PASSWORD=change_me

